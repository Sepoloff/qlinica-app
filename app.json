{
  "expo": {
    "name": "Qlinica",
    "slug": "qlinica-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.qlinica.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.qlinica.app",
      "versionCode": 1,
      "permissions": []
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": []
  }
}
